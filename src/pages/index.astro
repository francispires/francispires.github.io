---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import SkillBar from '../components/SkillBar.astro';
import TypewriterHero from '../components/TypewriterHero.astro';
import { getCollection } from 'astro:content';

// Fetch more than needed so filtering by language still shows ~3 posts
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 20);

const skills = [
  { name: 'C# / .NET Core',     pct: 99, color: 'var(--green)' },
  { name: 'TypeScript',          pct: 95, color: 'var(--cyan)'  },
  { name: 'React',               pct: 92, color: 'var(--cyan)'  },
  { name: 'SQL / PostgreSQL',    pct: 90, color: 'var(--amber)' },
  { name: 'Design Patterns/TDD', pct: 88, color: 'var(--green)' },
  { name: 'JavaScript / Node',   pct: 85, color: 'var(--cyan)'  },
  { name: 'Python',              pct: 82, color: 'var(--amber)' },
  { name: 'Oracle',              pct: 78, color: 'var(--amber)' },
  { name: 'SharePoint / M365',   pct: 75, color: 'var(--green)' },
  { name: 'Vercel / DevOps',     pct: 70, color: 'var(--cyan)'  },
  { name: 'ML / AI',             pct: 55, color: 'var(--amber)' },
];
---

<BaseLayout
  title="Francis Pires"
  description="C# specialist and software architect with 30 years of experience. Building web platforms with .NET Core, TypeScript, React, and Node.js."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <pre class="ascii-art" aria-hidden="true">
  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
  в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ
  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
  в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘
  в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘
  в•ҡв•җв•қ     в•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ</pre>

      <TypewriterHero />

      <div class="hero-bio">
        <span class="hb-prompt">$ cat ./intro.txt</span>
        <p class="hb-output lang-en">
          Full-stack developer &amp; software architect В· 30 years of experience<br/>
          C# / .NET Core В· TypeScript В· React В· Node.js В· Vercel<br/>
          SQL (MSSQL В· PostgreSQL В· Oracle) В· Python В· SharePoint<br/>
          Design Patterns В· TDD В· Clean Architecture
        </p>
        <p class="hb-output lang-pt">
          Desenvolvedor full-stack &amp; arquiteto de software В· 30 anos de experiГӘncia<br/>
          C# / .NET Core В· TypeScript В· React В· Node.js В· Vercel<br/>
          SQL (MSSQL В· PostgreSQL В· Oracle) В· Python В· SharePoint<br/>
          PadrГөes de Projeto В· TDD В· Arquitetura Limpa
        </p>
      </div>

      <div class="hero-actions">
        <a href="/projects" class="hero-btn primary">$ ls ./projects</a>
        <a href="/blog"     class="hero-btn secondary">$ cat ./blog/*</a>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span>skills <span class="sh-dim">// htop-style</span></span>
      </div>
      <div class="skills-grid">
        {skills.map(s => <SkillBar name={s.name} pct={s.pct} color={s.color} />)}
      </div>
    </div>
  </section>

  <!-- Recent posts -->
  {posts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <span>
            <span class="lang-en">recent posts</span>
            <span class="lang-pt">posts recentes</span>
            <a href="/blog" class="sh-more">вҶ’ <span class="lang-en">all</span><span class="lang-pt">todos</span></a>
          </span>
        </div>
        <div class="posts-list" id="home-posts">
          {posts.map(p => (
            <PostCard
              slug={p.slug}
              title={p.data.title}
              pubDate={p.data.pubDate}
              description={p.data.description}
              tags={p.data.tags}
              category={p.data.category}
              lang={p.data.lang}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {posts.length === 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header"><span>blog</span></div>
        <p class="no-posts">
          <span style="color: var(--text-dim)">$ ls ./blog/</span><br />
          <span style="color: var(--text-muted)">// No published posts yet. Check back soon.</span>
        </p>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    align-items: center;
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--border);
  }

  .ascii-art {
    font-size: clamp(0.28rem, 1vw, 0.62rem);
    color: var(--green);
    line-height: 1.2;
    margin-bottom: 2.5rem;
    overflow-x: auto;
    opacity: 0.8;
    background: none;
    border: none;
    padding: 0;
  }

  .hero-bio {
    margin: 1.5rem 0 0.5rem;
    font-size: 0.85rem;
  }

  .hb-prompt {
    display: block;
    color: var(--text-dim);
    font-size: 0.8rem;
    margin-bottom: 0.5rem;
  }

  .hb-output {
    margin: 0;
    padding-left: 1rem;
    border-left: 2px solid var(--border);
    color: var(--text);
    line-height: 2;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .hero-btn {
    display: inline-block;
    padding: 0.55rem 1.25rem;
    border-radius: 4px;
    font-size: 0.875rem;
    text-decoration: none;
    font-family: var(--font-mono);
    transition: all 0.15s ease;
  }

  .hero-btn.primary {
    background: var(--green);
    color: #000;
    font-weight: 700;
  }

  .hero-btn.primary:hover {
    background: var(--cyan);
    color: #000;
  }

  .hero-btn.secondary {
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  .hero-btn.secondary:hover {
    border-color: var(--green);
    color: var(--green);
  }

  .section {
    padding: 4rem 0;
    border-bottom: 1px solid var(--border);
  }

  .section:last-child { border-bottom: none; }

  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    max-width: 520px;
  }

  .sh-dim  { color: var(--text-dim); font-size: 0.8rem; }
  .sh-more { color: var(--text-muted); font-size: 0.8rem; text-decoration: none; margin-left: 0.5rem; }
  .sh-more:hover { color: var(--green); }

  .posts-list { display: flex; flex-direction: column; gap: 0.25rem; }

  .no-posts { font-size: 0.875rem; line-height: 2; }
</style>

<script>
  function filterHomePosts() {
    const lang = localStorage.getItem('site-lang') || 'pt-BR';
    const allCards = Array.from(document.querySelectorAll<HTMLElement>('#home-posts .post-card[data-post-lang]'));
    const langCards = allCards.filter(c => c.dataset.postLang === lang);
    // Fall back to all posts if no posts exist in the current language yet
    const toShow = langCards.length > 0 ? langCards.slice(0, 6) : allCards.slice(0, 6);
    allCards.forEach(card => {
      card.style.display = toShow.includes(card) ? '' : 'none';
    });
  }

  filterHomePosts();
  document.documentElement.addEventListener('langchange', filterHomePosts);
</script>
