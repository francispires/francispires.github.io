---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = [...new Set(allPosts.map(p => p.data.category))].sort();

const catEn: Record<string, string> = {
  'data-engineering': 'data-eng',
  'csharp': 'C#',
  'typescript': 'TypeScript',
};
const catPt: Record<string, string> = {
  'data-engineering': 'eng. dados',
  'misc': 'outros',
  'csharp': 'C#',
  'typescript': 'TypeScript',
};
function enCat(cat: string) { return catEn[cat] ?? cat; }
function ptCat(cat: string) { return catPt[cat] ?? cat; }
---

<BaseLayout
  title="Blog"
  description="Articles on C#, .NET, TypeScript, React, data engineering, and more."
>
  <div class="content-container page-wrap">

    <div class="page-header">
      <div class="section-header">
        <span>blog</span>
      </div>
      <div class="post-count">
        <span class="pd">$</span>
        <span class="lang-en">ls -la ./blog/ | wc -l →</span>
        <span class="lang-pt">ls -la ./blog/ | wc -l →</span>
        <span class="pn" id="post-count">{allPosts.length}</span>
        <span class="lang-en">posts</span>
        <span class="lang-pt">posts</span>
      </div>
    </div>

    <div class="cat-filter">
      <button class="cat-btn active" data-cat="all">
        <span class="lang-en">all</span>
        <span class="lang-pt">todos</span>
      </button>
      {categories.map(cat => (
        <button class="cat-btn" data-cat={cat}>
          <span class="lang-en">{enCat(cat)}</span>
          <span class="lang-pt">{ptCat(cat)}</span>
        </button>
      ))}
    </div>

    {allPosts.length > 0 ? (
      <div class="posts-list" id="posts-list">
        {allPosts.map(p => (
          <PostCard
            slug={p.slug}
            title={p.data.title}
            pubDate={p.data.pubDate}
            description={p.data.description}
            tags={p.data.tags}
            category={p.data.category}
            lang={p.data.lang}
          />
        ))}
      </div>
    ) : (
      <p class="empty">
        <span class="pd">$</span>
        <span class="lang-en" style="color: var(--text-muted)">// No published posts yet.</span>
        <span class="lang-pt" style="color: var(--text-muted)">// Nenhum post publicado ainda.</span>
      </p>
    )}
  </div>
</BaseLayout>

<script>
  let activeCat = 'all';

  function filterPosts() {
    const lang = localStorage.getItem('site-lang') || 'pt-BR';
    const allCards = Array.from(document.querySelectorAll<HTMLElement>('.post-card[data-post-lang]'));
    const langCards = allCards.filter(c => c.dataset.postLang === lang);
    // Fall back to all posts when no posts in the current language yet
    const langPool = langCards.length > 0 ? langCards : allCards;

    let visible = 0;
    allCards.forEach(card => {
      const inPool = langPool.includes(card);
      const matchesCat = activeCat === 'all' || card.dataset.category === activeCat;
      const show = inPool && matchesCat;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    const counter = document.getElementById('post-count');
    if (counter) counter.textContent = String(visible);
  }

  document.querySelectorAll<HTMLElement>('.cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      activeCat = btn.dataset.cat || 'all';
      document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      filterPosts();
    });
  });

  filterPosts();

  document.documentElement.addEventListener('langchange', filterPosts);
  window.addEventListener('storage', e => {
    if (e.key === 'site-lang') filterPosts();
  });
</script>

<style>
  .page-wrap { padding-top: 3rem; padding-bottom: 4rem; }

  .page-header { margin-bottom: 2rem; }

  .post-count { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.5rem; }
  .pd { color: var(--green); }
  .pn { color: var(--cyan); }

  .cat-filter { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 2rem; }

  .cat-btn {
    font-size: 0.75rem;
    padding: 0.2em 0.6em;
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text-muted);
    text-decoration: none;
    background: none;
    cursor: pointer;
    font-family: var(--font-mono);
    transition: all 0.12s ease;
    line-height: 1.6;
  }

  .cat-btn:hover,
  .cat-btn.active {
    border-color: var(--green);
    color: var(--green);
    background: rgba(0, 255, 135, 0.05);
  }

  .posts-list { display: flex; flex-direction: column; gap: 0.25rem; }

  .empty { font-size: 0.875rem; color: var(--text-muted); }
</style>
