---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = [...new Set(allPosts.map(p => p.data.category))].sort();
---

<BaseLayout
  title="Blog"
  description="Articles on data engineering, Python, SQL, JavaScript, and more."
>
  <div class="content-container page-wrap">

    <div class="page-header">
      <div class="section-header">
        <span class="lang-en">blog</span>
        <span class="lang-pt">blog</span>
      </div>
      <div class="post-count">
        <span class="pd">$</span>
        <span class="lang-en">ls -la ./blog/ | wc -l →</span>
        <span class="lang-pt">ls -la ./blog/ | wc -l →</span>
        <span class="pn" id="post-count">{allPosts.length}</span>
        <span class="lang-en">posts</span>
        <span class="lang-pt">posts</span>
      </div>
    </div>

    <div class="cat-filter">
      <a href="/blog" class="cat-btn active" data-cat="all">
        <span class="lang-en">all</span>
        <span class="lang-pt">todos</span>
      </a>
      {categories.map(cat => (
        <a href={`/blog/category/${cat}`} class="cat-btn" data-cat={cat}>{cat}</a>
      ))}
    </div>

    {allPosts.length > 0 ? (
      <div class="posts-list" id="posts-list">
        {allPosts.map(p => (
          <PostCard
            slug={p.slug}
            title={p.data.title}
            pubDate={p.data.pubDate}
            description={p.data.description}
            tags={p.data.tags}
            category={p.data.category}
            lang={p.data.lang}
          />
        ))}
      </div>
    ) : (
      <p class="empty">
        <span class="pd">$</span>
        <span class="lang-en" style="color: var(--text-muted)">// No published posts yet.</span>
        <span class="lang-pt" style="color: var(--text-muted)">// Nenhum post publicado ainda.</span>
      </p>
    )}
  </div>
</BaseLayout>

<script>
  function filterPosts() {
    const lang = localStorage.getItem('site-lang') || 'pt-BR';
    const cards = document.querySelectorAll<HTMLElement>('.post-card[data-post-lang]');
    let visible = 0;
    cards.forEach(card => {
      const matches = card.dataset.postLang === lang;
      card.style.display = matches ? '' : 'none';
      if (matches) visible++;
    });
    const counter = document.getElementById('post-count');
    if (counter) counter.textContent = String(visible);
  }

  filterPosts();

  // Re-filter when language toggles
  document.documentElement.addEventListener('langchange', filterPosts);

  // Also watch storage changes from other tabs
  window.addEventListener('storage', e => {
    if (e.key === 'site-lang') filterPosts();
  });
</script>

<style>
  .page-wrap { padding-top: 3rem; padding-bottom: 4rem; }

  .page-header { margin-bottom: 2rem; }

  .post-count { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.5rem; }
  .pd { color: var(--green); }
  .pn { color: var(--cyan); }

  .cat-filter { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 2rem; }

  .cat-btn {
    font-size: 0.75rem;
    padding: 0.2em 0.6em;
    border: 1px solid var(--border);
    border-radius: 3px;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.12s ease;
  }

  .cat-btn:hover,
  .cat-btn.active {
    border-color: var(--green);
    color: var(--green);
    background: rgba(0, 255, 135, 0.05);
  }

  .posts-list { display: flex; flex-direction: column; gap: 0.25rem; }

  .empty { font-size: 0.875rem; color: var(--text-muted); }
</style>
