---
interface Props {
  slug: string;
  title: string;
  description: string;
  tech: string[];
  featured?: boolean;
}

const { slug, title, description, tech, featured = false } = Astro.props;
---

<a href={`/projects/${slug}`} class={`project-card ${featured ? 'featured' : ''}`}>
  <div class="pc-header">
    <span class="pc-icon">{featured ? '★' : '◈'}</span>
    <h3 class="pc-title">{title}</h3>
  </div>
  <p class="pc-desc">{description}</p>
  <div class="pc-tech">
    {tech.map(t => <span class="tech-tag">{t}</span>)}
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    text-decoration: none;
    color: var(--text);
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .project-card:hover {
    border-color: var(--green);
    background: rgba(0, 255, 135, 0.03);
    color: var(--text);
  }

  .project-card.featured { border-color: rgba(0, 255, 135, 0.25); }

  .pc-header { display: flex; align-items: center; gap: 0.5rem; }
  .pc-icon { color: var(--green); font-size: 0.9rem; }

  .pc-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text);
    transition: color 0.15s ease;
  }

  .project-card:hover .pc-title { color: var(--green); }

  .pc-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
  }

  .pc-tech { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: auto; }

  .tech-tag {
    font-size: 0.7rem;
    background: var(--bg-elevated);
    color: var(--cyan);
    padding: 0.1em 0.5em;
    border-radius: 3px;
    border: 1px solid var(--border);
  }
</style>
